{
    "name":    "Eklips Engine",
    "version": {
        "app": "1.0",
        "ekl": "4.1A"
    },
    "viewport": {
        "size":       [648,   648],
        "color":      [35, 35, 50],
        "minsize":    [648,   648],
        "maxsize":    null,
        "resizable": true
    },
    "scenes": {
        "master":  "res://scenes/master.scn",
        "loading": "root://_assets/loading.scn"
    },
    
    "directory": "editor",

    "actions": {
        "test": {
            "actions":  [2],
            "holdable": true
        }
    },

    "cvars": {
        "icon_file": {
            "type":        "str",
            "default":     "res://media/icon.png",
            "description": "Image file to use for the icon"
        },
        "globals": {
            "type":        "list",
            "default":     [],
            "description": "List of Scripts to be loaded as Nodes 'AUTOL~X'"
        },
        "languages": {
            "type":        "list",
            "default":     ["en","fr","foobar"],
            "description": "List of languages used in the game"
        },
        "lang_dir": {
            "type":        "str",
            "default":     "res://lang",
            "description": "Directory where all the language files are"
        }
    }
}