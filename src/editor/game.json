{
    "name":    "Eklips Editor",
    "version": {
        "app": "5.0A",
        "ekl": "5.0A"
    },
    "viewport": {
        "size":       [648,   648],
        "color":      [35, 35, 50],
        "minsize":    [648,   648],
        "maxsize":    null,
        "resizable":  true,
        "icon_file":  "res://media/icon.png"
    },
    "scenes": {
        "master":  "res://scenes/master.scn",
        "loading": "root://_assets/loading.scn"
    },
    
    "directory": "editor",

    "actions": {
        "test": {
            "actions":  [2],
            "holdable": true
        }
    },

    "behavior": {
        "autoloads":     [],
        "autoload_name": "Autoload!~X",

        "antialiasing": false,

        "fonts": []
    },
    "language": {
        "langs": ["en","fr","foobar"],
        "dir":   "res://lang"
    }
}