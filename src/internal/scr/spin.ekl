# ver=4.0A / py=3.12

def _process(self, delta):
    rs = delta * 150
    self.rotation += rs

    if self.rotation > 360:
        self.alpha -= delta
        ekl = engine.scene.get_node_from_path("","Eclipse")
        ekl.alpha = self.alpha

    if self.alpha < 0:
        engine.load_new_scene(engine.cvars.get("master_scene"))